{
  "name": "brewform",
  "version": "1.0.0",
  "description": "Coffee dive-in recipe sharing platform",
  "license": "MIT",
  "nodeModulesDir": "auto",
  "lock": "deno.lock",
  "fmt": {
    "useTabs": false,
    "lineWidth": 100,
    "indentWidth": 2,
    "semiColons": true,
    "singleQuote": true,
    "exclude": [
      "node_modules",
      "dist",
      ".next",
      "coverage",
      "apps/api/prisma/migrations",
      "apps/api/prisma/generated"
    ]
  },
  "tasks": {
    "format": "deno fmt .",
    "format:check": "deno fmt --check .",
    "typecheck": "deno check apps/api/src/index.ts apps/web/src/main.tsx",
    "typecheck:api": "deno check apps/api/src/index.ts",
    "typecheck:web": "deno check apps/web/src/main.tsx"
  }
}
