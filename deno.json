{
  "name": "brewform",
  "version": "1.0.0",
  "description": "Coffee dive-in recipe sharing platform",
  "license": "MIT",
  "nodeModulesDir": "auto",
  "lock": "deno.lock",
  "imports": {
    "typescript": "npm:typescript@^5.9.3" // dev
  },
  "fmt": {
    "useTabs": false,
    "lineWidth": 100,
    "indentWidth": 2,
    "semiColons": true,
    "singleQuote": true,
    "exclude": [
      "node_modules",
      "dist",
      ".next",
      "coverage",
      "apps/api/prisma/migrations",
      "apps/api/prisma/generated"
    ]
  },
  "tasks": {
    "format": "deno fmt .",
    "format:check": "deno fmt --check ."
  }
}
