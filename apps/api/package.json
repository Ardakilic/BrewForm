{
  "name": "@brewform/api",
  "version": "1.0.0",
  "description": "BrewForm API — Hono backend",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "deno run --watch --allow-all src/index.ts",
    "start": "deno run --allow-all src/index.ts",
    "test": "deno test --allow-all --no-check --import-map=src/test/import_map.json src/",
    "test:watch": "deno test --allow-all --no-check --watch --import-map=src/test/import_map.json src/",
    "test:coverage": "deno test --allow-all --no-check --import-map=src/test/import_map.json --coverage=coverage src/",
    "test:coverage:report": "deno coverage coverage --lcov --output=coverage/lcov.info",
    "lint": "deno lint src/",
    "lint:fix": "deno lint --fix src/",
    "format": "deno fmt",
    "format:check": "deno fmt --check",
    "typecheck": "deno check src/index.ts",
    "check": "deno task lint && deno task format:check && deno task typecheck",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:seed": "deno run --allow-all prisma/seed.ts",
    "db:seed:taste-notes": "deno run --allow-all prisma/seed-taste-notes.ts",
    "db:studio": "prisma studio",
    "db:push": "prisma db push",
    "reset-password": "deno run --allow-all prisma/reset-password.ts",
    "clean": "rm -rf dist node_modules coverage"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.7.6",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@node-rs/argon2": "^2.0.2",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "hono": "^4.12.8",
    "jose": "^6.2.2",
    "mjml": "^4.18.0",
    "nanoid": "^5.1.7",
    "nodemailer": "^8.0.3",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "slugify": "^1.6.8",
    "zod": "^4.3.6"
  },
  "optionalDependencies": {
    "redis": "^4.7.0"
  },
  "devDependencies": {
    "@types/mjml": "^4.7.4",
    "@types/node": "^25.5.0",
    "@types/nodemailer": "^7.0.11",
    "pino-pretty": "^13.1.3",
    "prisma": "^7.5.0"
  }
}
