{
  "name": "@brewform/api",
  "version": "1.0.0",
  "description": "BrewForm API - Hono backend",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts --format esm --dts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "biome lint ./src",
    "lint:fix": "biome lint --write ./src",
    "format": "biome format --write ./src",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:taste-notes": "tsx prisma/seed-taste-notes.ts",
    "db:studio": "prisma studio",
    "reset-password": "tsx prisma/reset-password.ts",
    "db:push": "prisma db push",
    "clean": "rm -rf dist node_modules .turbo coverage"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "@hono/zod-validator": "^0.7.6",
    "@prisma/client": "^7.5.0",
    "@node-rs/argon2": "^2.0.2",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "hono": "^4.12.8",
    "ioredis": "^5.10.1",
    "jose": "^6.2.2",
    "mjml": "^4.18.0",
    "nanoid": "^5.1.7",
    "nodemailer": "^8.0.3",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "slugify": "^1.6.8",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/mjml": "^4.7.4",
    "@types/node": "^25.5.0",
    "@types/nodemailer": "^7.0.11",
    "@vitest/coverage-v8": "^4.1.0",
    "pino-pretty": "^13.1.3",
    "prisma": "^7.5.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
