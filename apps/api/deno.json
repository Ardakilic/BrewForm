{
  "name": "@brewform/api",
  "version": "1.0.0",
  "description": "BrewForm API - Hono backend",
  "exports": "./src/index.ts",
  "nodeModulesDir": "auto",
  "lock": "deno.lock",
  "imports": {
    "@hono/zod-validator": "npm:@hono/zod-validator@^0.7.6",
    "@prisma/adapter-pg": "npm:@prisma/adapter-pg@^7.5.0",
    "@prisma/client": "npm:@prisma/client@^7.5.0",
    "@node-rs/argon2": "npm:@node-rs/argon2@^2.0.2",
    "date-fns": "npm:date-fns@^4.1.0",
    "date-fns-tz": "npm:date-fns-tz@^3.2.0",
    "hono": "npm:hono@^4.12.8",
    "ioredis": "npm:ioredis@^5.10.1",
    "jose": "npm:jose@^6.2.2",
    "mjml": "npm:mjml@^4.18.0",
    "nanoid": "npm:nanoid@^5.1.7",
    "nodemailer": "npm:nodemailer@^8.0.3",
    "pino": "npm:pino@^10.3.1",
    "pino-http": "npm:pino-http@^11.0.0",
    "slugify": "npm:slugify@^1.6.8",
    "zod": "npm:zod@^4.3.6",
    "@types/mjml": "npm:@types/mjml@^4.7.4", // dev
    "@types/node": "npm:@types/node@^25.5.0", // dev
    "@types/nodemailer": "npm:@types/nodemailer@^7.0.11", // dev
    "pino-pretty": "npm:pino-pretty@^13.1.3", // dev
    "prisma": "npm:prisma@^7.5.0" // dev
  },
  "compilerOptions": {
    "lib": ["ES2022", "ES2022.Full", "deno.ns"],
    "types": ["node"],
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true
  },
  "fmt": {
    "exclude": ["prisma/generated", "prisma/migrations"]
  },
  "tasks": {
    "dev": "deno run --watch --allow-all src/index.ts",
    "start": "deno run --allow-all src/index.ts",
    "test": "deno test --allow-all --no-check --import-map=src/test/import_map.json src/",
    "test:watch": "deno test --allow-all --no-check --watch --import-map=src/test/import_map.json src/",
    "lint": "deno lint src/",
    "lint:fix": "deno lint --fix src/",
    "format": "deno fmt",
    "format:check": "deno fmt --check",
    "typecheck": "deno check src/index.ts",
    "check": "deno task lint && deno task format:check && deno task typecheck",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:seed": "deno run --allow-all prisma/seed.ts",
    "db:seed:taste-notes": "deno run --allow-all prisma/seed-taste-notes.ts",
    "db:studio": "prisma studio",
    "db:push": "prisma db push",
    "reset-password": "deno run --allow-all prisma/reset-password.ts",
    "clean": "rm -rf dist node_modules coverage"
  }
}
