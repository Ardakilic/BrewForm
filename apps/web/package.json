{
  "name": "@brewform/web",
  "version": "1.0.0",
  "description": "BrewForm Web — React frontend",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "deno test --allow-all --no-check --import-map=src/test/import_map.json src/",
    "test:watch": "deno test --allow-all --no-check --watch --import-map=src/test/import_map.json src/",
    "test:coverage": "deno test --allow-all --no-check --import-map=src/test/import_map.json --coverage=coverage src/",
    "test:coverage:report": "deno coverage coverage --lcov --output=coverage/lcov.info",
    "lint": "deno lint src/",
    "lint:fix": "deno lint --fix src/",
    "format": "deno fmt",
    "format:check": "deno fmt --check",
    "typecheck": "deno check src/main.tsx",
    "check": "deno task lint && deno task format:check && deno task typecheck",
    "clean": "rm -rf dist node_modules coverage"
  },
  "dependencies": {
    "baseui": "^16.1.1",
    "date-fns": "^4.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-helmet-async": "^3.0.0",
    "react-hook-form": "^7.71.2",
    "react-i18next": "^16.6.0",
    "react-router-dom": "^7.13.1",
    "styletron-engine-monolithic": "^1.0.0",
    "styletron-react": "^6.1.1",
    "swr": "^2.4.1",
    "zod": "^4.3.6",
    "@hookform/resolvers": "^5.2.2",
    "i18next": "^26.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "jsdom": "^29.0.1",
    "vite": "^8.0.1"
  }
}
