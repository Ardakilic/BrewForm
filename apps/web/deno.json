{
  "imports": {
    "@std/testing": "jsr:@std/testing@^1.0.0/bdd",
    "@std/expect": "jsr:@std/expect@^1.0.0",
    "@std/testing/mock": "jsr:@std/testing@^1.0.0/mock"
  },
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "strict": true,
    "lib": ["ES2022", "DOM"],
    "types": ["vite/client"]
  },
  "lint": {
    "rules": {
      "tags": ["recommended"]
    }
  },
  "fmt": {
    "useTabs": false,
    "lineWidth": 100,
    "indentWidth": 2,
    "semiColons": true,
    "singleQuote": true
  }
}
