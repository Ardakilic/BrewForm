# ===========================================
# BrewForm Environment Configuration
# ===========================================

# Application
NODE_ENV=development
APP_NAME=BrewForm
APP_URL=http://localhost:3000
API_URL=http://localhost:3001
APP_SECRET=your-super-secret-key-change-in-production
API_VERSION=v1

# Database
DATABASE_URL=postgresql://brewform:brewform@postgres:5432/brewform?schema=public
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# JWT
JWT_SECRET=your-jwt-secret-key-change-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Email (SMTP)
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM_NAME=BrewForm
SMTP_FROM_EMAIL=noreply@brewform.local

# Logging
LOG_LEVEL=debug
LOG_FORMAT=pretty

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Pagination
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# File Upload
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp

# Session
SESSION_SECRET=your-session-secret-change-in-production
SESSION_MAX_AGE=604800000

# Admin (First admin credentials - password will be generated on first run)
ADMIN_EMAIL=admin@brewform.local

# ============================================
# Cache Layer
# ============================================
# Backend: deno-kv (default, SQLite-backed, no extra deps)
#        | redis    (requires Redis container; use `make dev-redis`)
CACHE_DRIVER=deno-kv
CACHE_REQUIRED=false
# Deno KV persistence path (bind-mounted volume in compose.yml)
CACHE_DENO_KV_PATH=/data/deno-kv/brewform.kv
# Redis (only used when CACHE_DRIVER=redis)
CACHE_REDIS_URL=redis://redis:6379
CACHE_REDIS_PASSWORD=
# TTLs in seconds
CACHE_TTL_RECIPES_LATEST=300
CACHE_TTL_RECIPES_POPULAR=300
CACHE_TTL_RECIPES_LIST=120
CACHE_TTL_TASTE_NOTES=86400
CACHE_TTL_RECIPE_DETAIL=600

# Analytics
ENABLE_ANALYTICS=true

# Feature Flags
ENABLE_REGISTRATION=true
ENABLE_EMAIL_VERIFICATION=true
ENABLE_PASSWORD_RESET=true

# Timezone
DEFAULT_TIMEZONE=UTC

# Localization
DEFAULT_LOCALE=en
SUPPORTED_LOCALES=en,es,de,fr,it,tr,ja,ko,zh
